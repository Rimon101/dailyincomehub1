{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "installCommand": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/tasks", "destination": "/pages/tasks/index.html" },
    { "source": "/profile", "destination": "/pages/profile/index.html" },
    { "source": "/balance", "destination": "/pages/balance/index.html" },
    { "source": "/recharge", "destination": "/pages/recharge/index.html" },
    { "source": "/withdrawal", "destination": "/pages/withdrawal/index.html" },
    { "source": "/login", "destination": "/pages/login/index.html" },
    { "source": "/register", "destination": "/pages/register/index.html" },
    { "source": "/forgot-password", "destination": "/pages/forgot-password/index.html" },
    { "source": "/reset-password", "destination": "/pages/reset-password/index.html" },
    { "source": "/service", "destination": "/pages/service/index.html" },
    { "source": "/trust", "destination": "/pages/trust/index.html" },
    { "source": "/history", "destination": "/pages/history/index.html" },
    { "source": "/team", "destination": "/pages/team/index.html" },
    { "source": "/admin", "destination": "/pages/admin/index.html" },
    { "source": "/bind-wallet", "destination": "/pages/bind-wallet/index.html" },
    { "source": "/change-password", "destination": "/pages/change-password/index.html" },
    { "source": "/language", "destination": "/pages/language/index.html" },
    { "source": "/edit-profile", "destination": "/pages/profile/edit-profile.html" },
    { "source": "/withdraw-management", "destination": "/pages/profile/withdraw-management.html" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "statusCode": 301 },
    { "source": "/pages/tasks/index.html", "destination": "/tasks", "statusCode": 301 },
    { "source": "/pages/profile/index.html", "destination": "/profile", "statusCode": 301 },
    { "source": "/pages/balance/index.html", "destination": "/balance", "statusCode": 301 },
    { "source": "/pages/recharge/index.html", "destination": "/recharge", "statusCode": 301 },
    { "source": "/pages/withdrawal/index.html", "destination": "/withdrawal", "statusCode": 301 },
    { "source": "/pages/login/index.html", "destination": "/login", "statusCode": 301 },
    { "source": "/pages/register/index.html", "destination": "/register", "statusCode": 301 },
    { "source": "/pages/forgot-password/index.html", "destination": "/forgot-password", "statusCode": 301 },
    { "source": "/pages/reset-password/index.html", "destination": "/reset-password", "statusCode": 301 },
    { "source": "/pages/service/index.html", "destination": "/service", "statusCode": 301 },
    { "source": "/pages/trust/index.html", "destination": "/trust", "statusCode": 301 },
    { "source": "/pages/history/index.html", "destination": "/history", "statusCode": 301 },
    { "source": "/pages/team/index.html", "destination": "/team", "statusCode": 301 },
    { "source": "/pages/admin/index.html", "destination": "/admin", "statusCode": 301 },
    { "source": "/pages/bind-wallet/index.html", "destination": "/bind-wallet", "statusCode": 301 },
    { "source": "/pages/change-password/index.html", "destination": "/change-password", "statusCode": 301 },
    { "source": "/pages/language/index.html", "destination": "/language", "statusCode": 301 },
    { "source": "/admin.html", "destination": "/admin", "statusCode": 301 },
    { "source": "/balance.html", "destination": "/balance", "statusCode": 301 },
    { "source": "/bind-wallet.html", "destination": "/bind-wallet", "statusCode": 301 },
    { "source": "/change_password.html", "destination": "/change-password", "statusCode": 301 },
    { "source": "/history.html", "destination": "/history", "statusCode": 301 },
    { "source": "/login.html", "destination": "/login", "statusCode": 301 },
    { "source": "/profile.html", "destination": "/profile", "statusCode": 301 },
    { "source": "/profile/profile.html", "destination": "/profile", "statusCode": 301 },
    { "source": "/profile/edit-profile.html", "destination": "/edit-profile", "statusCode": 301 },
    { "source": "/profile/withdraw-management.html", "destination": "/withdraw-management", "statusCode": 301 },
    { "source": "/edit-profile.html", "destination": "/edit-profile", "statusCode": 301 },
    { "source": "/withdraw-management.html", "destination": "/withdraw-management", "statusCode": 301 },
    { "source": "/recharge.html", "destination": "/recharge", "statusCode": 301 },
    { "source": "/register.html", "destination": "/register", "statusCode": 301 },
    { "source": "/service.html", "destination": "/service", "statusCode": 301 },
    { "source": "/tasks.html", "destination": "/tasks", "statusCode": 301 },
    { "source": "/trust.html", "destination": "/trust", "statusCode": 301 },
    { "source": "/withdrawal.html", "destination": "/withdrawal", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).jpeg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ]
}
