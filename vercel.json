{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "installCommand": null,
  "redirects": [
    { "source": "/home", "destination": "/", "statusCode": 301 },
    { "source": "/admin.html", "destination": "/pages/admin/index.html", "statusCode": 301 },
    { "source": "/balance.html", "destination": "/pages/balance/index.html", "statusCode": 301 },
    { "source": "/balance", "destination": "/pages/balance/index.html", "statusCode": 301 },
    { "source": "/bind-wallet.html", "destination": "/pages/bind-wallet/index.html", "statusCode": 301 },
    { "source": "/bind-wallet", "destination": "/pages/bind-wallet/index.html", "statusCode": 301 },
    { "source": "/change_password.html", "destination": "/pages/change-password/index.html", "statusCode": 301 },
    { "source": "/change-password", "destination": "/pages/change-password/index.html", "statusCode": 301 },
    { "source": "/history.html", "destination": "/pages/history/index.html", "statusCode": 301 },
    { "source": "/history", "destination": "/pages/history/index.html", "statusCode": 301 },
    { "source": "/login.html", "destination": "/pages/login/index.html", "statusCode": 301 },
    { "source": "/profile.html", "destination": "/pages/profile/index.html", "statusCode": 301 },
    { "source": "/profile", "destination": "/pages/profile/index.html", "statusCode": 301 },
    { "source": "/profile/profile.html", "destination": "/pages/profile/index.html", "statusCode": 301 },
    { "source": "/recharge.html", "destination": "/pages/recharge/index.html", "statusCode": 301 },
    { "source": "/recharge", "destination": "/pages/recharge/index.html", "statusCode": 301 },
    { "source": "/register.html", "destination": "/pages/register/index.html", "statusCode": 301 },
    { "source": "/register", "destination": "/pages/register/index.html", "statusCode": 301 },
    { "source": "/service.html", "destination": "/pages/service/index.html", "statusCode": 301 },
    { "source": "/service", "destination": "/pages/service/index.html", "statusCode": 301 },
    { "source": "/tasks.html", "destination": "/pages/tasks/index.html", "statusCode": 301 },
    { "source": "/tasks", "destination": "/pages/tasks/index.html", "statusCode": 301 },
    { "source": "/trust.html", "destination": "/pages/trust/index.html", "statusCode": 301 },
    { "source": "/trust", "destination": "/pages/trust/index.html", "statusCode": 301 },
    { "source": "/withdrawal.html", "destination": "/pages/withdrawal/index.html", "statusCode": 301 },
    { "source": "/withdrawal", "destination": "/pages/withdrawal/index.html", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(.*).jpeg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ]
}
