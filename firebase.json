{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "firestore.rules",
      "fix_paths.js",
      "package.json",
      "package-lock.json"
    ],
    "redirects": [
      { "source": "/home", "destination": "/", "type": 301 },
      { "source": "/admin.html", "destination": "/pages/admin/index.html", "type": 301 },
      { "source": "/balance.html", "destination": "/pages/balance/index.html", "type": 301 },
      { "source": "/balance", "destination": "/pages/balance/index.html", "type": 301 },
      { "source": "/bind-wallet.html", "destination": "/pages/bind-wallet/index.html", "type": 301 },
      { "source": "/bind-wallet", "destination": "/pages/bind-wallet/index.html", "type": 301 },
      { "source": "/change_password.html", "destination": "/pages/change-password/index.html", "type": 301 },
      { "source": "/change-password", "destination": "/pages/change-password/index.html", "type": 301 },
      { "source": "/history.html", "destination": "/pages/history/index.html", "type": 301 },
      { "source": "/history", "destination": "/pages/history/index.html", "type": 301 },
      { "source": "/login.html", "destination": "/pages/login/index.html", "type": 301 },
      { "source": "/profile.html", "destination": "/pages/profile/index.html", "type": 301 },
      { "source": "/profile", "destination": "/pages/profile/index.html", "type": 301 },
      { "source": "/profile/profile.html", "destination": "/pages/profile/index.html", "type": 301 },
      { "source": "/recharge.html", "destination": "/pages/recharge/index.html", "type": 301 },
      { "source": "/recharge", "destination": "/pages/recharge/index.html", "type": 301 },
      { "source": "/register.html", "destination": "/pages/register/index.html", "type": 301 },
      { "source": "/register", "destination": "/pages/register/index.html", "type": 301 },
      { "source": "/service.html", "destination": "/pages/service/index.html", "type": 301 },
      { "source": "/service", "destination": "/pages/service/index.html", "type": 301 },
      { "source": "/tasks.html", "destination": "/pages/tasks/index.html", "type": 301 },
      { "source": "/tasks", "destination": "/pages/tasks/index.html", "type": 301 },
      { "source": "/trust.html", "destination": "/pages/trust/index.html", "type": 301 },
      { "source": "/trust", "destination": "/pages/trust/index.html", "type": 301 },
      { "source": "/withdrawal.html", "destination": "/pages/withdrawal/index.html", "type": 301 },
      { "source": "/withdrawal", "destination": "/pages/withdrawal/index.html", "type": 301 }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "/images/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      },
      {
        "source": "**/*.{webp,png,jpg,jpeg}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      }
    ],
    "rewrites": []
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
