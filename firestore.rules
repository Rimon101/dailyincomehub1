rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is an Admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    // Rules for the Users collection
    match /users/{userId} {
      // Allow any user to see their own data, or an Admin to see all
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Allow list queries for:
      // 1. Unauthenticated username/invite code checks (must limit results to 1)
      // 2. Authenticated users listing their own referrals (referredBy / inviteCode)
      // 3. Admin panel lists
      allow list: if 
        (request.query.limit != null && request.query.limit <= 1) ||
        (request.auth != null && (
          resource.data.referredBy == request.auth.uid || 
          resource.data.referralCodeEntered == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.inviteCode ||
          isAdmin()
        ));
      // Allow creation during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow updates to personal profile or Admin full control, preventing normal users from modifying sensitive admin-only fields
      allow update: if request.auth != null && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'vipLevel', 'username', 'email', 'createdAt', 'referredBy', 'referralCodeEntered', 'firstRechargeDone'])) || 
        isAdmin()
      );
    }

    // Rules for Withdrawals and Recharges
    match /withdrawals/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
    
    match /recharges/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Rules for Global Config (Admin Only)
    match /globalConfig/{document} {
      allow read: if request.auth != null; // Everyone needs to see site status/name
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
